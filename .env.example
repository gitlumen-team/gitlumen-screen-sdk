GITHUB_TOKEN=
GITLUMEN_SCREEN_DATA_DIR=.gitlumen-screen-sdk
GITLUMEN_MAX_FILE_BYTES=120000

GITLUMEN_AI_PROVIDER=heuristic
GITLUMEN_PROVIDER_ERROR_MODE=attach

SURPLUS_API_KEY=
SURPLUS_BASE_URL=https://www.surplusintelligence.ai/x402/api/inference/v1
SURPLUS_CHAT_COMPLETIONS_PATH=/chat/completions
SURPLUS_MODEL=auto
SURPLUS_TEMPERATURE=0.2
SURPLUS_MAX_TOKENS=1800
SURPLUS_TIMEOUT_MS=45000
SURPLUS_MAX_INPUT_CHARS=60000
SURPLUS_MAX_FILE_CHARS=6000

VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_CHAT_COMPLETIONS_PATH=/chat/completions
VENICE_MODEL=zai-org-glm-5
VENICE_TEMPERATURE=0.2
VENICE_MAX_TOKENS=1800
VENICE_TIMEOUT_MS=45000
VENICE_MAX_INPUT_CHARS=60000
VENICE_MAX_FILE_CHARS=6000